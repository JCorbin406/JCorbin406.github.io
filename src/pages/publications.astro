---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationEntry from '../components/PublicationEntry.astro';
import pubs from '../data/publications.json';

// Group by year, sorted descending
const years = [...new Set(pubs.map(p => p.year))].sort((a, b) => b - a);
const grouped = years.map(year => ({
  year,
  papers: pubs.filter(p => p.year === year),
}));
---

<BaseLayout title="Publications | Johnathan (Jack) Corbin">
  <div class="page-container">
    <h1>// publications</h1>

    {grouped.map(group => (
      <section class="section">
        <h2>$ grep {group.year}</h2>
        <div class="panel">
          {group.papers.map(pub => (
            <PublicationEntry
              title={pub.title}
              authors={pub.authors}
              venue={pub.venue}
              year={pub.year}
              link={pub.link || undefined}
              bibtex={pub.bibtex || undefined}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
