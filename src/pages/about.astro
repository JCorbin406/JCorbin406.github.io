---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Johnathan (Jack) Corbin">
  <div class="page-container">
    <h1>// about</h1>

    <section class="section">
      <div class="panel id-badge">
        <div class="id-badge-header">[ ID BADGE ]</div>
        <div class="id-badge-body">
          <div class="id-badge-photo">
            <img src="/JCorbin_square.png" alt="Johnathan (Jack) Corbin" />
          </div>
          <div class="id-badge-info">
            <div class="id-row"><span class="id-key">name</span><span class="id-sep">:</span><span>Johnathan (Jack) Corbin</span></div>
            <div class="id-row"><span class="id-key">role</span><span class="id-sep">:</span><span>PhD Student</span></div>
            <div class="id-row"><span class="id-key">dept</span><span class="id-sep">:</span><span>Aerospace Engineering</span></div>
            <div class="id-row"><span class="id-key">inst</span><span class="id-sep">:</span><span>Georgia Institute of Technology</span></div>
            <div class="id-row"><span class="id-key">status</span><span class="id-sep">:</span><span class="text-amber">ACTIVE</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>$ cat bio.txt</h2>
      <div class="panel">
        <p>
          I'm a Robotics PhD student at the Georgia Institute of Technology in the Daniel
          Guggenheim School of Aerospace Engineering, where my research focuses on multi-agent
          control and UAS deployment.
        </p>
        <p>
          Before Georgia Tech, I spent three years as a Senior Engineer at Physical Sciences,
          Inc. (PSI), working on deployable space structures, antennas, and robotic systems
          for defense and space applications. I hold a BS in Aeronautical Engineering from
          Rensselaer Polytechnic Institute, where I conducted research in wire arc additive
          manufacturing and autonomous industrial systems.
        </p>
      </div>
    </section>

    <section class="section">
      <h2>$ cat education.log</h2>
      <div class="panel">
        <div class="timeline-entry">
          <span class="text-amber">PhD Robotics</span> — Georgia Institute of Technology
          <span class="text-dim">| 2023 – Present</span>
          <p class="timeline-desc">Qualifying exam passed March 2025.</p>
        </div>
        <div class="timeline-entry">
          <span class="text-amber">MS Aerospace Engineering</span> — Georgia Institute of Technology
          <span class="text-dim">| Expected August 2026</span>
        </div>
        <div class="timeline-entry">
          <span class="text-amber">BS Aeronautical Engineering</span> — Rensselaer Polytechnic Institute
          <span class="text-dim">| 2016 – 2020</span>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>$ cat experience.log</h2>
      <div class="panel">
        <div class="timeline-entry">
          <span class="text-amber">Senior Engineer</span> — Physical Sciences, Inc. (PSI)
          <span class="text-dim">| 2020 – 2023</span>
          <p class="timeline-desc">Deployable technologies R&D: antennas, space structures, robotic systems, shock/vibration damping. SBIR/STTR proposals for DoD.</p>
        </div>
        <div class="timeline-entry">
          <span class="text-amber">Undergraduate Research Assistant</span> — Manufacturing Innovation Center, RPI
          <span class="text-dim">| 2017 – 2020</span>
          <p class="timeline-desc">Autonomous industrial systems: wind turbine assembly, robotic welding, wire arc additive manufacturing.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>$ tree skills/ --info</h2>
      <div class="panel skill-tree">
        <p class="tree-hint">Click a directory to expand or collapse its contents.</p>
        <div class="tree-root">skills/</div>

        <details class="tree-category" open>
          <summary><span class="tree-branch">├── </span><span class="tree-dir">programming_languages/</span></summary>
          <div class="tree-children">
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Python</span><span class="tree-leader"></span><span class="tree-context">multi-agent sim, data analysis</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">MATLAB</span><span class="tree-leader"></span><span class="tree-context">control systems, orbital mechanics</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">C++</span><span class="tree-leader"></span><span class="tree-context">embedded systems, ROS nodes</span></div>
            <div class="tree-item"><span class="tree-branch">│   └── </span><span class="tree-file">Java</span><span class="tree-leader"></span><span class="tree-context">academic coursework</span></div>
          </div>
        </details>

        <details class="tree-category">
          <summary><span class="tree-branch">├── </span><span class="tree-dir">frameworks/</span></summary>
          <div class="tree-children">
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">ROS</span><span class="tree-leader"></span><span class="tree-context">multi-robot coordination</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Gazebo</span><span class="tree-leader"></span><span class="tree-context">robotics simulation</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">OpenCV</span><span class="tree-leader"></span><span class="tree-context">computer vision</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Simulink</span><span class="tree-leader"></span><span class="tree-context">controls, dynamics modeling</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">LaTeX</span><span class="tree-leader"></span><span class="tree-context">publications, proposals</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Arduino</span><span class="tree-leader"></span><span class="tree-context">sensor integration</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Git</span><span class="tree-leader"></span><span class="tree-context">version control</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Linux</span><span class="tree-leader"></span><span class="tree-context">Ubuntu, CLI, system admin</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">LabVIEW</span><span class="tree-leader"></span><span class="tree-context">test automation, DAQ</span></div>
            <div class="tree-item"><span class="tree-branch">│   └── </span><span class="tree-file">KiCad</span><span class="tree-leader"></span><span class="tree-context">PCB layout, schematic capture</span></div>
          </div>
        </details>

        <details class="tree-category">
