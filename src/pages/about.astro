        <details class="tree-category">
          <summary><span class="tree-branch">├── </span><span class="tree-dir">testing/</span></summary>
          <div class="tree-children">
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Experiment Design</span><span class="tree-leader"></span><span class="tree-context">DOE, test planning</span></div>
