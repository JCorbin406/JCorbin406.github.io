            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Engineering Drawings</span><span class="tree-leader"></span><span class="tree-context">ASME Y14.5, detail & assembly</span></div>
            <div class="tree-item"><span class="tree-branch">│   └── </span><span class="tree-file">Metrology</span><span class="tree-leader"></span><span class="tree-context">calipers, micrometers, CMM</span></div>
