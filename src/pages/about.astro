<style>
  .timeline-entry {
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(var(--primary-rgb), 0.08);
    font-size: 0.9rem;
  }

  .timeline-entry:last-child {
    border-bottom: none;
  }

  .timeline-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.3rem;
    margin-bottom: 0;
  }

  /* ── Option B: Interactive Tree ── */
  .skill-tree {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .tree-hint {
    color: var(--text-dim);
    font-size: 0.8rem;
    margin: 0 0 0.75rem 0;
    font-style: italic;
  }

  .tree-root {
    color: var(--amber);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .tree-category {
    margin: 0;
  }

  .tree-category summary {
    cursor: pointer;
    list-style: none;
    white-space: pre;
  }

  .tree-category summary::-webkit-details-marker {
    display: none;
  }

  .tree-dir {
    color: var(--amber);
    font-weight: 700;
  }

  .tree-category summary .tree-dir::before {
    content: '▸ ';
    font-size: 0.7em;
  }

  .tree-category[open] summary .tree-dir::before {
    content: '▾ ';
    font-size: 0.7em;
  }

  .tree-children {
    white-space: pre;
  }

  .tree-branch {
    color: var(--primary);
    user-select: none;
  }

  .tree-file {
    color: var(--text);
  }

  .tree-leader {
    display: inline;
  }

  .tree-leader::after {
    content: ' ·················· ';
    color: var(--text-dim);
    font-size: 0.75em;
  }

  .tree-context {
    color: var(--text-dim);
    font-size: 0.8em;
    font-style: italic;
  }

  .tree-item {
    white-space: pre;
  }

  .cv-link {
    font-size: 1rem;
    text-shadow: var(--glow-md);
  }

  .id-badge {
    overflow: hidden;
  }

  .id-badge-header {
    color: var(--amber);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    text-shadow: 0 0 8px rgba(255, 176, 0, 0.4);
  }

  .id-badge-body {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .id-badge-photo {
    flex-shrink: 0;
  }

  .id-badge-photo img {
    width: 140px;
    height: 175px;
    object-fit: cover;
    border: 2px solid var(--green);
    display: block;
    box-shadow: 0 0 12px rgba(var(--primary-rgb), 0.15);
  }

  .id-badge-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.9rem;
  }

  .id-row {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .id-key {
    color: var(--amber);
    font-weight: 700;
    min-width: 55px;
    text-align: right;
  }

  .id-sep {
    color: var(--text-dim);
  }

  @media (max-width: 768px) {
    .id-badge-body {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .id-key {
      text-align: left;
    }

    .id-row {
      justify-content: center;
    }
  }
</style>

