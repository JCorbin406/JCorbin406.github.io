          <div class="tree-children">
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">Circuit Design</span><span class="tree-leader"></span><span class="tree-context">schematic capture, analysis</span></div>
            <div class="tree-item"><span class="tree-branch">│   ├── </span><span class="tree-file">PCB Design</span><span class="tree-leader"></span><span class="tree-context">layout, routing</span></div>
