---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon = '>' } = Astro.props;
---

<div class="research-card panel">
  <h3><span class="text-amber">{icon}</span> {title}</h3>
  <p>{description}</p>
</div>

<style>
  .research-card {
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .research-card:hover {
    border-color: rgba(var(--primary-rgb), 0.5);
    box-shadow: 0 0 20px rgba(var(--primary-rgb), 0.05);
  }

  .research-card h3 {
    margin-bottom: 0.75rem;
  }

  .research-card p {
    font-size: 0.85rem;
    color: var(--text);
    margin-bottom: 0;
    line-height: 1.6;
  }
</style>
